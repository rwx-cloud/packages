#!/usr/bin/env bash
set -ueo pipefail

if [ "$MOD_DOWNLOAD_PATH" = "" ]; then
  >&2 echo "MOD_DOWNLOAD_PATH was not found."
  exit 2
fi

cd "${MOD_DOWNLOAD_PATH}"

GOMODCACHE="$(go env GOMODCACHE)"
CACHE_FILE="${GOMODCACHE}/.rwx-mod-download.json"
mkdir -p "${GOMODCACHE}"

echo "Determining modules to download in ${MOD_DOWNLOAD_PATH}"

# Get all remote modules (excluding workspace main modules)
mod_json=$(go list -m -json all | jq -s '
  [
    .[]
    | select(.Main | not)
    | (.Replace // .)
    | select((.Version // "") != "")
    | {Path, Version}
  ]
  | unique_by(.Path, .Version)
')

mod_versions=()
while IFS= read -r mod_version; do
  mod_versions+=("${mod_version}")
done < <(echo "${mod_json}" | jq -r '.[] | "\(.Path)@\(.Version)"')

mod_count="${#mod_versions[@]}"

echo "Found ${mod_count} modules to download"

# Build reuse flag if cache file exists from previous run
download_args=(-json)
if [ -f "$CACHE_FILE" ]; then
  echo "Found previous download state, using -reuse for incremental download"
  download_args+=("-reuse=$CACHE_FILE")
fi

# Download modules from outside module directory (-reuse requires this)
# Save JSON output for next run
if [ "${mod_count}" -eq 0 ]; then
  echo "No remote modules to download"
  : > "$CACHE_FILE.tmp"
else
  echo "Downloading modules"
  cd "${GOMODCACHE}"
  go mod download "${download_args[@]}" "${mod_versions[@]}" > "$CACHE_FILE.tmp"
fi

mv "$CACHE_FILE.tmp" "$CACHE_FILE"

echo "Downloaded ${mod_count} modules"
